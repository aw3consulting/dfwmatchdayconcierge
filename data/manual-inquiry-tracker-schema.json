{
  "version": "1.0.0",
  "purpose": "Define the minimum manual inquiry tracker fields for 24-hour launch readiness.",
  "privacy_rule": "Private client, driver, concierge, payment, and sensitive data must not be stored in public GitHub files.",
  "storage_mode_for_launch": "manual private tracker outside public repo",
  "required_fields": [
    "inquiry_id",
    "created_at",
    "lane",
    "lead_source",
    "client_or_coordinator_name",
    "phone",
    "email",
    "preferred_contact_method",
    "matchday_or_event",
    "arrival_date",
    "departure_date",
    "airport",
    "hotel_or_stay_area",
    "origin",
    "destination",
    "group_size",
    "luggage_count",
    "service_needs",
    "budget_or_payment_readiness",
    "quote_status",
    "deposit_status",
    "confirmation_status",
    "driver_status",
    "concierge_status",
    "fulfillment_path",
    "escalation_status",
    "closeout_status",
    "privacy_flag",
    "monetization_source",
    "follow_up_date",
    "operator_owner",
    "notes"
  ],
  "allowed_status_values": {
    "quote_status": ["not_started", "review_needed", "drafting", "sent", "accepted", "declined"],
    "deposit_status": ["not_applicable", "pending", "requested", "received", "waived"],
    "confirmation_status": ["inquiry", "review", "quoted", "payment_pending", "confirmed", "declined", "referred", "restricted"],
    "driver_status": ["not_needed", "needed", "reviewing", "offered", "accepted", "assigned", "unavailable"],
    "concierge_status": ["not_needed", "needed", "reviewing", "assigned", "unavailable"],
    "fulfillment_path": ["not_started", "direct_service", "driver_path", "concierge_path", "referral", "information_only", "restricted", "escalation", "closeout"],
    "escalation_status": ["none", "monitor", "urgent", "blocked", "resolved"],
    "closeout_status": ["open", "completed", "cancelled", "referred", "declined"]
  }
}
